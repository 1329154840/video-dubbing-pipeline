# ── 虚拟环境 ──────────────────────────────────────────────────────────────────
venv/
.venv/
env/

# ── 运行时数据（视频、音频、字幕、TTS 音频）────────────────────────────────────
workspace/*
!workspace/.gitkeep

# ── ffmpeg 捆绑包（体积太大，用户自行安装）──────────────────────────────────────
ffmpeg-btbn/
ffmpeg*/

# ── Python 缓存 ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── 环境变量 / 密钥 ───────────────────────────────────────────────────────────
.env
*.env
*.key

# ── 系统文件 ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── 日志 ──────────────────────────────────────────────────────────────────────
*.log
app_log.txt
app_err.txt
pipeline_v2*.log

# ── 旧版文件（已迁移到 workspace/）───────────────────────────────────────────
tts_v2/
translation_saves/
translation.json
translation_v2.json
dubbed_*.wav
dubbed_*.mp4
subtitles_*.srt
*.en-orig.srt
*.en-orig.json3
original_video.*
subtitles_zh.srt
